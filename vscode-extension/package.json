{
  "name": "bsl-analyzer",
  "displayName": "BSL Analyzer (1C)",
  "description": "Language support for 1C BSL: syntax highlighting, diagnostics, go-to-definition, hover, completions, formatting, rename and more",
  "version": "0.6.5",
  "publisher": "mussolene",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mussolene/1c_hbk_bsl"
  },
  "bugs": {
    "url": "https://github.com/mussolene/1c_hbk_bsl/issues"
  },
  "homepage": "https://github.com/mussolene/1c_hbk_bsl#readme",
  "galleryBanner": {
    "color": "#1e3a5f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Snippets"
  ],
  "keywords": [
    "1C",
    "BSL",
    "1C Enterprise",
    "OneScript",
    "bsl-language-server"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:bsl",
    "onCommand:bslAnalyzer.reindexWorkspace",
    "onCommand:bslAnalyzer.reindexCurrentFile",
    "onCommand:bslAnalyzer.showStatus",
    "onCommand:bslAnalyzer.showOutput"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bsl",
        "aliases": [
          "BSL",
          "1C Enterprise Script",
          "OneScript"
        ],
        "extensions": [
          ".bsl",
          ".os"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bsl",
        "scopeName": "source.bsl",
        "path": "./syntaxes/bsl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "bsl",
        "path": "./snippets/bsl.json"
      }
    ],
    "commands": [
      {
        "command": "bslAnalyzer.reindexWorkspace",
        "title": "BSL Analyzer: Reindex Workspace",
        "category": "BSL"
      },
      {
        "command": "bslAnalyzer.reindexCurrentFile",
        "title": "BSL Analyzer: Reindex Current File",
        "category": "BSL"
      },
      {
        "command": "bslAnalyzer.showStatus",
        "title": "BSL Analyzer: Show Index Status",
        "category": "BSL"
      },
      {
        "command": "bslAnalyzer.showOutput",
        "title": "BSL Analyzer: Show Server Log",
        "category": "BSL"
      }
    ],
    "configuration": {
      "title": "BSL Analyzer",
      "properties": {
        "bslAnalyzer.serverPath": {
          "type": "string",
          "default": "bsl-analyzer",
          "description": "Path to the bsl-analyzer executable. Leave as 'bsl-analyzer' to use the version on PATH."
        },
        "bslAnalyzer.useDocker": {
          "type": "boolean",
          "default": false,
          "description": "Run bsl-analyzer inside Docker instead of a local binary."
        },
        "bslAnalyzer.dockerContainer": {
          "type": "string",
          "default": "bsl-analyzer-default",
          "description": "Docker container name to use when bslAnalyzer.useDocker is true."
        },
        "bslAnalyzer.indexDbPath": {
          "type": "string",
          "default": "",
          "description": "SQLite index path. Leave empty: server stores the index under .git/bsl_index.sqlite (git repo) or ~/.cache/bsl-analyzer/<id>/ (otherwise). Set only to force a custom location."
        },
        "bslAnalyzer.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warning",
            "error"
          ],
          "default": "info",
          "description": "Log level for the BSL analyzer language server."
        },
        "bslAnalyzer.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time diagnostics (linting) as you type."
        },
        "bslAnalyzer.diagnostics.select": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Run only the listed diagnostic rule codes. Empty = all rules."
        },
        "bslAnalyzer.diagnostics.ignore": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Suppress the listed diagnostic rule codes."
        },
        "bslAnalyzer.format.indentSize": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces per indentation level when formatting BSL code."
        },
        "bslAnalyzer.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name hints at function call sites."
        },
        "bslAnalyzer.semanticTokens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic token coloring (layered on top of syntax highlighting)."
        }
      }
    },
    "configurationDefaults": {
      "[bsl]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "mussolene.bsl-analyzer",
        "editor.semanticHighlighting.enabled": true,
        "editor.inlayHints.enabled": "on",
        "editor.tabSize": 4,
        "editor.insertSpaces": false
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit -p ./",
    "lint": "eslint .",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies",
    "package:vsix": "vsce package --no-dependencies -o bsl-analyzer-${npm_package_version}.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^9.28.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.34.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
