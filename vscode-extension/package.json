{
  "name": "1c-hbk-bsl",
  "displayName": "1C HBK BSL",
  "description": "1C Enterprise BSL: syntax highlighting, diagnostics, go-to-definition, hover, completions, formatting, rename, and more",
  "version": "0.7.8",
  "publisher": "mussolene",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mussolene/1c_hbk_bsl"
  },
  "bugs": {
    "url": "https://github.com/mussolene/1c_hbk_bsl/issues"
  },
  "homepage": "https://github.com/mussolene/1c_hbk_bsl#readme",
  "galleryBanner": {
    "color": "#1565C0",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Snippets"
  ],
  "keywords": [
    "1C",
    "BSL",
    "1C Enterprise",
    "OneScript",
    "1C HBK",
    "bsl-language-server"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "bsl",
        "aliases": [
          "BSL",
          "1C Enterprise Script",
          "OneScript"
        ],
        "extensions": [
          ".bsl",
          ".os"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bsl",
        "scopeName": "source.bsl",
        "path": "./syntaxes/bsl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "bsl",
        "path": "./snippets/bsl.json"
      }
    ],
    "commands": [
      {
        "command": "onecHbkBsl.reindexWorkspace",
        "title": "Reindex Workspace",
        "category": "1C HBK BSL"
      },
      {
        "command": "onecHbkBsl.reindexCurrentFile",
        "title": "Reindex Current File",
        "category": "1C HBK BSL"
      },
      {
        "command": "onecHbkBsl.showStatus",
        "title": "Show Index Status",
        "category": "1C HBK BSL"
      },
      {
        "command": "onecHbkBsl.showOutput",
        "title": "Show Server Log",
        "category": "1C HBK BSL"
      }
    ],
    "configuration": {
      "title": "1C HBK BSL",
      "properties": {
        "onecHbkBsl.serverPath": {
          "type": "string",
          "default": "onec-hbk-bsl",
          "description": "Path to the onec-hbk-bsl executable. Default placeholder skips this override; the extension uses the bundled or downloaded binary unless you set a real filesystem path here."
        },
        "onecHbkBsl.useDocker": {
          "type": "boolean",
          "default": false,
          "description": "Run onec-hbk-bsl inside Docker instead of a local binary."
        },
        "onecHbkBsl.dockerContainer": {
          "type": "string",
          "default": "onec-hbk-bsl-default",
          "description": "Docker container name to use when onecHbkBsl.useDocker is true."
        },
        "onecHbkBsl.indexDbPath": {
          "type": "string",
          "default": "",
          "description": "SQLite index path. Leave empty: server stores the index under .git/onec-hbk-bsl_index.sqlite (git repo) or ~/.cache/onec-hbk-bsl/<id>/ (otherwise). Set only to force a custom location."
        },
        "onecHbkBsl.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warning",
            "error"
          ],
          "default": "info",
          "description": "Log level for the 1C HBK BSL language server."
        },
        "onecHbkBsl.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time diagnostics (linting) as you type."
        },
        "onecHbkBsl.diagnostics.select": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Run only the listed diagnostic rule codes. Empty = all rules."
        },
        "onecHbkBsl.diagnostics.ignore": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Suppress the listed diagnostic rule codes."
        },
        "onecHbkBsl.format.indentSize": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces per indentation level when formatting BSL code."
        },
        "onecHbkBsl.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name hints at function call sites."
        },
        "onecHbkBsl.semanticTokens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic token coloring (layered on top of syntax highlighting)."
        }
      }
    },
    "configurationDefaults": {
      "[bsl]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.defaultFormatter": "mussolene.1c-hbk-bsl",
        "editor.semanticHighlighting.enabled": true,
        "editor.inlayHints.enabled": "on",
        "editor.tabSize": 4,
        "editor.insertSpaces": false
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit -p ./",
    "lint": "eslint .",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "unset npm_config_devdir NPM_CONFIG_DEVDIR; npx @vscode/vsce package --no-dependencies",
    "package:vsix": "unset npm_config_devdir NPM_CONFIG_DEVDIR; npx @vscode/vsce package --no-dependencies -o 1c-hbk-bsl-${npm_package_version}.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.28.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.34.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
